---
import Layout from '~/layouts/Layout.astro';
import ToggleTheme from '~/components/common/ToggleTheme.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import profileImg from '~/assets/images/github-profile.jpeg';

const metadata = {
  title: 'Rogério Pontes',
  description:
    'Security Engineering Manager with a Ph.D. in Computer Science, 9 peer-reviewed publications, and a track record of building security teams and cloud infrastructure at scale.',
};

const socials = [
  { icon: 'tabler:brand-linkedin', href: 'https://www.linkedin.com/in/rogerioacp', label: 'LinkedIn' },
  { icon: 'tabler:brand-github', href: 'https://github.com/rogerioacp', label: 'GitHub' },
  { icon: 'tabler:news', href: 'https://rogeriopontes.substack.com/', label: 'Substack' },
  { icon: 'tabler:brand-x', href: 'https://x.com/rogerio_acp', label: 'X / Twitter' },
];
---

<Layout metadata={metadata}>
  <!-- Theme toggle -->
  <div class="fixed top-4 right-4 z-50">
    <ToggleTheme />
  </div>

  <!-- Card -->
  <main class="min-h-screen flex items-center justify-center px-4 py-12">
    <div class="max-w-xl w-full text-center" data-animate>
      <!-- Photo -->
      <Image
        src={profileImg}
        alt="Rogério Pontes"
        width={160}
        height={160}
        class="w-40 h-40 rounded-full mx-auto mb-6 object-cover object-[center_30%] shadow-lg"
      />

      <!-- Name -->
      <h1 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl">
        Rogério Pontes
      </h1>

      <!-- Title -->
      <p class="mt-2 text-sm font-semibold uppercase tracking-widest text-primary">
        Security Engineering Manager
      </p>
      <p class="mt-1 text-base text-muted">
        Ph.D. in Computer Science · University of Porto
      </p>

      <!-- Bio -->
      <p class="mt-4 text-muted leading-relaxed">
        I bridge the gap between academic research and industry practice to build a security
        strategy that is effective, scalable and rigorous. As Engineering Manager at AutoScout24, I manage
        a security team of five engineers and shape the whole company security strategy. My Ph.D. in Computer Science (University of Porto) and 10 publications at top venues (CSF, SRDS, SYSTOR) in cryptography and privacy-preserving
        systems give me a research-driven edge to tackle security challenges that off-the-shelf
        solutions cannot.
      </p>

      <!-- Social links -->
      <div class="mt-6 flex items-center justify-center gap-4">
        {socials.map(({ icon, href, label }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={label}
            class="text-muted hover:text-primary transition-colors duration-200"
          >
            <Icon name={icon} class="w-6 h-6" />
          </a>
        ))}
      </div>

      <!-- Contact button -->
      <div class="mt-8">
        <a
          href="mailto:rogerio.a.pontes@outlook.com?subject=Security service for <Your Company Name>"
          class="btn-primary"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="fixed bottom-0 inset-x-0 py-4 text-center text-sm text-muted">
    &copy; {new Date().getFullYear()} Rogério Pontes. All rights reserved.
  </footer>
</Layout>
